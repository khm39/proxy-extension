{
  "name": "proxy-extension",
  "displayName": "Proxy Switcher",
  "version": "0.0.1",
  "description": "プロキシサーバーの設定と切り替えを簡単に行える Chrome 拡張機能",
  "author": "khm39",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "@plasmohq/messaging": "0.7.2",
    "@plasmohq/storage": "1.15.0",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "prettier": "3.2.4",
    "typescript": "5.3.3"
  },
  "manifest": {
    "permissions": [
      "proxy",
      "storage",
      "webRequest",
      "webRequestAuthProvider"
    ],
    "host_permissions": [
      "<all_urls>"
    ]
  }
}
