{
  "name": "proxy-extension",
  "displayName": "Proxy Switcher",
  "version": "1.0.0",
  "description": "プロキシサーバーの設定と切り替えを簡単に行える Chrome 拡張機能",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "@plasmohq/messaging": "^0.7.0",
    "@plasmohq/storage": "^1.13.0",
    "plasmo": "^0.90.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.7.0"
  },
  "manifest": {
    "permissions": [
      "proxy",
      "storage",
      "webRequest",
      "webRequestAuthProvider"
    ],
    "host_permissions": [
      "<all_urls>"
    ]
  }
}
